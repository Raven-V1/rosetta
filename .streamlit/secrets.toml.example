# Streamlit Secrets Template for Rosetta Application
# 
# INSTRUCTIONS FOR LOCAL DEVELOPMENT:
# 1. Copy this file to 'secrets.toml' in the same directory (.streamlit/)
# 2. Fill in your actual API keys and credentials
# 3. NEVER commit the actual secrets.toml file to version control
#
# FOR STREAMLIT CLOUD DEPLOYMENT:
# - Add these secrets through the Streamlit Cloud dashboard
# - Go to: App Settings > Secrets
# - Paste the content with your actual values
#
# NOTE: The actual secrets.toml file is already excluded in .gitignore

# Groq API Configuration
# Required for AI-powered documentation generation features
GROQ_API_KEY = "your-groq-api-key-here"

# Optional: SQL Server Configuration (if using database connectivity)
# Uncomment and fill in if your application uses SQL Server
# [connections.sqlserver]
# server = "your-server.database.windows.net"
# database = "your-database-name"
# username = "your-username"
# password = "your-password"
# driver = "ODBC Driver 17 for SQL Server"

# Optional: Additional API Keys
# Add any other API keys or secrets your application needs
# EXAMPLE_API_KEY = "your-api-key-here"