# IBM watsonx.ai Configuration
# Required for AI-powered documentation generation

# Your IBM Cloud API Key
# Get this from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# Your watsonx.ai Project ID
# Get this from: https://dataplatform.cloud.ibm.com/projects/?context=wx
# Navigate to your project → Manage → General → Project ID
WATSONX_PROJECT_ID=your_watsonx_project_id_here